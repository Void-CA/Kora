digraph KoraStructure {
    rankdir=TB;
    node [shape=folder];

    kora [label="kora/"];

    app [label="app/"];
    tests [label="tests/"];

    domain [label="domain/"];
    application [label="application/"];
    infrastructure [label="infrastructure/"];
    interfaces [label="interfaces/"];

    parcel [label="parcel/"];
    crop_cycle [label="crop_cycle/"];
    production [label="production/"];

    usecases [label="use_cases/"];
    analytics [label="analytics/"];

    db [label="db/"];
    repos [label="repositories/"];

    api [label="api/"];
    routes [label="routes/"];
    schemas [label="schemas/"];

    kora -> app;
    kora -> tests;

    app -> domain;
    app -> application;
    app -> infrastructure;
    app -> interfaces;

    domain -> parcel;
    domain -> crop_cycle;
    domain -> production;

    application -> usecases;
    application -> analytics;

    infrastructure -> db;
    db -> repos;

    interfaces -> api;
    api -> routes;
    api -> schemas;
}