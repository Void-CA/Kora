digraph KoraFeatureFlow {
    rankdir=LR;
    node [shape=box, style=rounded];

    subgraph cluster_interface {
        label="Interface Layer (FastAPI)";
        style=dashed;
        color=gray;

        api [label="API Route\nPOST /crop-cycles"];
        dto [label="DTO (Pydantic)\nRegisterCycleDTO"];
    }

    subgraph cluster_application {
        label="Application Layer";
        style=dashed;
        color=blue;

        usecase [label="Use Case\nRegisterCropCycle"];
    }

    subgraph cluster_domain {
        label="Domain Layer";
        style=dashed;
        color=green;

        entity1 [label="Parcel Entity"];
        entity2 [label="CropCycle Entity"];
        entity3 [label="Production Entity"];

        repo_interface [label="Repository Interface\n(CropCycleRepository)"];
    }

    subgraph cluster_infra {
        label="Infrastructure Layer";
        style=dashed;
        color=orange;

        repo_impl [label="SQL Repository\n(PostgreSQL + PostGIS)"];
        db [label="Database"];
    }

    api -> dto [label="validate input"];
    dto -> usecase [label="DTO → command"];

    usecase -> entity1 [label="load parcel"];
    usecase -> entity2 [label="create cycle"];
    usecase -> entity3 [label="init production"];

    usecase -> repo_interface [label="save"];

    repo_interface -> repo_impl [label="implemented by"];
    repo_impl -> db [label="persist data"];

    db -> repo_impl [label="data"];
    repo_impl -> usecase [label="entities"];
    usecase -> api [label="response"];
}